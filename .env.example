STARTGG_API_TOKEN=your_startgg_api_token_here
PORT=3001
STARTGG_OWNER_ID=89983ed7
# Vista regional: mismo criterio que la búsqueda web (lat,lon + radio en metros si es solo número)
# Ver: https://www.start.gg/search/tournaments (aroundLatLng / aroundRadius)
STARTGG_REGION_COORDINATES=10.9970723,-63.91132959999999
STARTGG_REGION_RADIUS=40233
INSTAGRAM_HANDLE=_boisgang
INSTAGRAM_FOLLOWERS_FALLBACK=750
# Deprecated (manual allowlist, optional):
STARTGG_ALLOWED_TOURNAMENT_SLUGS=
STARTGG_ALLOWED_TOURNAMENT_IDS=

# --- Vercel (Project → Settings → Environment Variables) ---
# Copia estas claves en Preview y Production (no subas .env al repo).
# STARTGG_API_TOKEN        obligatorio para /api/tournaments/* y /api/about/stats
# STARTGG_OWNER_ID         torneos Solo BoisGang (owner en start.gg)
# STARTGG_REGION_COORDINATES  opcional; por defecto en código si falta
# STARTGG_REGION_RADIUS    opcional; número = metros, o texto tipo 45km
# INSTAGRAM_HANDLE         /api/about/stats
# INSTAGRAM_FOLLOWERS_FALLBACK
# PORT                     ignorado en Vercel (solo local para proxy.js)
